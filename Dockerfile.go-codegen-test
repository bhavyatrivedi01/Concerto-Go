FROM node:20-alpine
WORKDIR /workspace
RUN npm install -g @accordproject/concerto-cli --ignore-scripts
COPY models/ ./models/
RUN concerto compile \
    --model models/test.cto \
    --target golang \
    --output /output

# Verify .go files were actually generated
RUN echo "=== Generated files ===" && \
    ls -la /output && \
    test $(ls /output/*.go 2>/dev/null | wc -l) -gt 0 && \
    echo "SUCCESS: Go files generated correctly"
