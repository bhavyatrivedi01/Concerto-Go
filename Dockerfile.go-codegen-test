FROM node:20-alpine AS codegen
WORKDIR /workspace
RUN npm install -g @accordproject/concerto-cli --ignore-scripts
COPY models/ ./models/
RUN concerto compile \
    --model models/test.cto \
    --target golang \
    --output /output && \
    echo "=== Generated files ===" && \
    ls -la /output
 
FROM golang:1.22-alpine AS test
WORKDIR /app
RUN go mod init concerto_codegen_test
 
# Copy generated files into /app/staging, then move each .go file
# into a subdirectory named after its package
COPY --from=codegen /output /app/staging
RUN for f in /app/staging/*.go; do \
      pkg=$(grep -m1 "^package" "$f" | awk '{print $2}'); \
      mkdir -p "/app/$pkg"; \
      cp "$f" "/app/$pkg/"; \
    done && \
    rm -rf /app/staging
 
RUN go mod tidy && go build ./...
 
