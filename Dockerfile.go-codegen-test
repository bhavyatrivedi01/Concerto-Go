# ============================================================
# Stage 1: Node.js + Concerto CLI (code generation)
# ============================================================
FROM node:20-alpine AS codegen

WORKDIR /workspace

# Install @accordproject/concerto-cli globally
# --ignore-scripts skips the postinstall lint checks that require
# lockfile-lint (not available in the alpine environment)
RUN npm install -g @accordproject/concerto-cli --ignore-scripts

# Copy the Concerto model(s) into the image
COPY models/ ./models/

# Run code generation for Go target
# Output is placed in /workspace/generated/go/
RUN mkdir -p generated/go && \
    concerto compile \
      --model models/test.cto \
      --target golang \
      --output generated/go

# ============================================================
# Stage 2: Go runtime (compile + test generated code)
# ============================================================
FROM golang:1.22-alpine AS test

# Set working directory to where go.mod lives
WORKDIR /app/tests/go

# Copy the hand-written Go test harness (includes go.mod)
COPY tests/go/ .

# Copy the generated Go source from the codegen stage into
# the path the test module expects it
COPY --from=codegen /workspace/generated/go ./generated/go/

# Build: ensure the generated code compiles without errors
RUN go build ./...

# Run tests (working directory is already /app/tests/go)
CMD ["go", "test", "-v", "./..."]
