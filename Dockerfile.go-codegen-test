# ============================================================
# Stage 1: Node.js + Concerto CLI (code generation)
# ============================================================
FROM node:20-alpine AS codegen

WORKDIR /workspace

RUN npm install -g @accordproject/concerto-cli --ignore-scripts

COPY models/ ./models/

RUN mkdir -p generated/go && \
    concerto compile \
      --model models/test.cto \
      --target golang \
      --output generated/go

# ============================================================
# Stage 2: Go runtime (compile + test generated code)
# ============================================================
FROM golang:1.25-alpine AS test

WORKDIR /app

# Copy the generated Go source from the codegen stage
COPY --from=codegen /workspace/generated/go ./

# Copy the test file into the same directory as the generated code
COPY tests/go/codegen_test.go ./

# Create a minimal go.mod for this single package
RUN go mod init concerto_codegen_test && go mod tidy

# Run tests
CMD ["go", "test", "-v", "./..."]
